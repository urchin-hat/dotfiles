# シェル設定（bash）
shell-integration = bash
command = /bin/bash --login

# ターミナル互換性設定
term = xterm-256color

# キーボード・入力設定
auto-update = off

# 外観設定
theme = "GitHub Dark Default"
font-family = "Monaspace Neon"
font-feature = calt
font-feature = liga
font-feature = dlig
font-size = 14

# クイックターミナル設定
quick-terminal-position = bottom
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.1
quick-terminal-autohide = false

# マウス設定
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# カーソル設定
cursor-opacity = 0.8
cursor-style = underline
cursor-style-blink = true

# ウィンドウ・レイアウト設定
unfocused-split-opacity = 0.825
fullscreen = false
window-inherit-working-directory = true
resize-overlay = never

# ペースト設定
clipboard-paste-protection = false
clipboard-paste-bracketed-safe = true

# 終了確認
confirm-close-surface = true

# 分割画面の境界線
split-divider-color = #39FF14

# キーバインド設定
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = alt+q=quit

# ウィンドウ・タブ操作
keybind = alt+shift+w=new_window
keybind = alt+t=new_tab
keybind = alt+w=close_tab
keybind = ctrl+shift+z=new_split:up
keybind = ctrl+shift+x=new_split:down
keybind = ctrl+shift+s=new_split:left
keybind = ctrl+shift+d=new_split:right

# 分割画面間の移動
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom

# タブ切り替え（1-9）
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=goto_tab:9
