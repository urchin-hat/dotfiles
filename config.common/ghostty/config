# シェル設定（bash）
shell-integration = bash
command = /bin/bash --login

# ターミナル互換性設定
term = xterm-256color

# キーボード・入力設定
auto-update = off

# 外観設定
theme = "GitHub Dark Default"
font-family = "Hack Nerd Font"
font-feature = -calt
font-feature = -dlig
font-size = 14

# クイックターミナル設定
quick-terminal-position = bottom
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.1
quick-terminal-autohide = false

# マウス設定
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# カーソル設定
cursor-opacity = 0.8
cursor-style = underline
cursor-style-blink = true

# ウィンドウ・レイアウト設定
unfocused-split-opacity = 0.825
fullscreen = true
window-inherit-working-directory = true
resize-overlay = never

# ペースト設定
clipboard-paste-protection = false
clipboard-paste-bracketed-safe = true

# 終了確認
confirm-close-surface = true

# 分割画面の境界線
split-divider-color = #39FF14

# キーバインド設定
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = cmd+q=quit

# ウィンドウ・タブ操作
keybind = cmd+alt+w=new_window
keybind = cmd+t=new_tab
keybind = cmd+w=close_tab
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# 分割画面間の移動
keybind = cmd+a=goto_split:left
keybind = cmd+s=goto_split:right
keybind = cmd+alt+a=goto_split:down
keybind = cmd+alt+s=goto_split:up

# タブ切り替え（1-9）
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=goto_tab:9
